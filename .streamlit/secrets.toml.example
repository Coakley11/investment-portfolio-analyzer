# Copy to secrets.toml locally (gitignored) or paste into Streamlit Cloud → Settings → Secrets
# Use the same block on EVERY suite app deployment (Command Center + Music + Baseball + …).

[suite_activity]
supabase_url = "https://YOUR_PROJECT.supabase.co"
supabase_key = "YOUR_SERVICE_ROLE_KEY"
# Identical suite_user_id on every app + device (phone and laptop share memory)
suite_user_id = "daniel"
suite_user_email = "you@example.com"
